{
	"name": "@packages/db",
	"version": "0.0.1",
	"private": true,
	"main": "./src/index.ts",
	"type": "module",
	"types": "./src/index.ts",
	"scripts": {
		"db:generate": "drizzle-kit generate --config ../../apps/desktop/drizzle.config.ts",
		"db:migrate:desktop": "drizzle-kit migrate --config ../../apps/desktop/drizzle.config.ts",
		"db:migrate:mobile": "drizzle-kit generate --config ../../apps/mobile/drizzle.config.ts",
		"db:migrate:web": "drizzle-kit migrate --config ../../apps/web/drizzle.config.ts",
		"db:studio": "drizzle-kit studio --config ../../apps/desktop/drizzle.config.ts",
		"db:push": "drizzle-kit push",
		"db:migrate": "drizzle-kit migrate",
		"generate:sql": "tsx scripts/generate-sql.ts > src/generated-sql.json"
	},
	"dependencies": {
		"@libsql/client": "^0.17.3",
		"drizzle-orm": "^0.45.2",
		"expo-sqlite": "^55.0.16"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"better-sqlite3": "^12.10.0",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.22.0",
		"typescript": "^6.0.3"
	}
}
