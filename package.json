{
	"name": "BookmarkReader",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"check": "biome check --write .",
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:mobile": "turbo -F mobile dev",
		"dev:web": "turbo -F web dev",
		"dev:desktop": "turbo dev",
		"build:marketing": "cd apps/marketing && pnpm build",
		"deploy:marketing": "cd apps/marketing && pnpm deploy"
	},
	"devDependencies": {
		"drizzle-orm": "0.45.1",
		"turbo": "^2.5.4"
	},
	"packageManager": "pnpm@11.1.2"
}
